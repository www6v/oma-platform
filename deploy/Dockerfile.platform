FROM golang:1.22 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /oma-server ./cmd/oma-server

# Use Docker Hub instead of gcr.io/distroless (often blocked or slow in CN).
FROM debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build /oma-server /app/oma-server
EXPOSE 8787
ENTRYPOINT ["/app/oma-server"]
