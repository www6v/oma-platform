OMA_API_KEY=dev-key
OMA_FAKE_HARNESS=1
# Console UI (optional): build with ./scripts/build-console.sh, then:
# CONSOLE_DIR=../open-managed-agents/apps/console/dist
CONSOLE_DIR=
# Real auth (better-auth sidecar). Set AUTH_DISABLED=1 only for local API-key-only dev.
AUTH_DISABLED=0
AUTH_UPSTREAM_URL=http://127.0.0.1:8788
AUTH_DATABASE_PATH=./data/auth.db
BETTER_AUTH_SECRET=
PUBLIC_BASE_URL=http://127.0.0.1:8787
# Optional: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
SMOKE_MODEL=claude-sonnet-4-6
# Fallback when agent.model has no matching model card (see GET /v1/model_cards)
ANTHROPIC_API_KEY=
# piPy reads ~/.pi/agent/{settings,models,auth}.json when no model card key is set
DATABASE_PATH=./data/oma.db
SANDBOX_WORKDIR=./data/sandboxes
HARNESS_URL=http://127.0.0.1:8090
# Default environment env-local-default is created on server start; override via
# POST /v1/sessions { "environment_id": "..." }
#
# Smoke: ./smoke-test.sh (LLM + bash/uname tools) or SMOKE_SKIP_LLM=1 (P1 APIs only)
# Optional: SMOKE_SKIP_TOOLS=1 SMOKE_TOOLS_ONLY=1 SMOKE_TOOL_TIMEOUT_SEC=180
# Optional: SMOKE_MODEL_CARD_ID=smoke-claude SMOKE_MODEL=claude-sonnet-4-6
