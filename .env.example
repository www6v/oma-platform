# --- Docker build mirrors (CN / slow networks; optional overrides) ---
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn
APT_MIRROR=mirrors.aliyun.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# --- Server / API ---
OMA_API_KEY=dev-key
PUBLIC_BASE_URL=http://127.0.0.1:8787

# --- Data storage ---
DATABASE_PATH=./data/oma.db
SANDBOX_WORKDIR=./data/sandboxes
SKILLS_DATA_DIR=./data/skills
FILES_DATA_DIR=./data/files
SESSION_OUTPUTS_DIR=./data/session-outputs
AUTH_DATABASE_PATH=./data/auth.db

# --- Harness (piPy sidecar) ---
HARNESS_URL=http://127.0.0.1:8090
# 1 = in-process fake harness (no Python / no LLM); 0 = real harness
OMA_FAKE_HARNESS=1

# --- Console UI (optional) ---
# Build: ./scripts/build-console.sh
# CONSOLE_DIR=./console/dist
CONSOLE_DIR=

# --- Authentication (better-auth sidecar) ---
# Set AUTH_DISABLED=1 only for local API-key-only dev (not production)
AUTH_DISABLED=0
AUTH_UPSTREAM_URL=http://127.0.0.1:8788
BETTER_AUTH_SECRET=
# Optional OAuth: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET

# --- LLM / model cards ---
# Fallback when agent.model has no matching model card (see GET /v1/model_cards)
ANTHROPIC_API_KEY=
# Shared secret for harness-side model credential fetch (x-internal-secret header)
# GET /v1/internal/model_cards/{id}/key?tenant_id=...
# GET /v1/internal/model_cards/resolve?tenant_id=...&model_id=...
OMA_INTERNAL_SECRET=
# piPy reads ~/.pi/agent/{settings,models,auth}.json when no model card key is set

# --- Sessions ---
# Default environment env-local-default is created on server start; override via
# POST /v1/sessions { "environment_id": "..." }

# --- Smoke test (./scripts/smoke-test.sh) ---
SMOKE_MODEL=claude-sonnet-4-6
# LLM + bash/uname tools, or SMOKE_SKIP_LLM=1 (P1+P2 APIs only, no harness)
# Optional: SMOKE_SKIP_P2=1 (skip skills/vault/console stubs)
# Console integration: ./scripts/console-integration.sh
#   UI dogfood: cd scripts && npm install && node console-dogfood.mjs
#   Uses cached Playwright shell if npx playwright install chromium is slow
# Optional: SMOKE_SKIP_TOOLS=1 SMOKE_TOOLS_ONLY=1 SMOKE_TOOL_TIMEOUT_SEC=180
# Optional: SMOKE_MODEL_CARD_ID=smoke-claude SMOKE_MODEL=claude-sonnet-4-6
